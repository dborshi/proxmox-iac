# External Redis
REDIS_HOSTNAME={{ redis_host }}
REDIS_PORT=6379
REDIS_PASSWORD='{{ immich_redis_password }}'
REDIS_DBINDEX=0

# JWT
JWT_SECRET='{{ immich_jwt_secret }}'