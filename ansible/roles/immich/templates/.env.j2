# Managed by Ansible - do not edit manually
UPLOAD_LOCATION={{ immich_media_dir }}
IMMICH_VERSION=release
TZ=Europe/Tirane

# External PostgreSQL
DB_HOSTNAME={{ postgres_host }}
DB_PORT=5432
DB_USERNAME=immich
DB_PASSWORD='{{ immich_db_password }}'
DB_DATABASE_NAME=immich
