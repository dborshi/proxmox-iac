web:
  port: 8080

storage:
  type: memory

metrics: true

endpoints:
  - name: Grafana
    url: http://grafana:3000
    interval: 1m
    conditions:
      - "[STATUS] == 200"

  - name: VictoriaMetrics
    url: http://victoriametrics:8428
    interval: 1m
    conditions:
      - "[STATUS] == 200"

  - name: VictoriaLogs
    url: http://victorialogs:9428
    interval: 1m
    conditions:
      - "[STATUS] == 200"
